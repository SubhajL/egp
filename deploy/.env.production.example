# e-GP Intelligence Platform — production env template
#
# Copy to /etc/egp/egp.env (mode 0600, owned by the egp service user) and
# fill in CHANGE_ME_* placeholders before deploying.
#
# Loadable by:
#   * docker compose --env-file deploy/egp.env up -d
#   * systemd unit:           EnvironmentFile=/etc/egp/egp.env
#   * shell:                  set -a; . /etc/egp/egp.env; set +a
#
# Categorization:
#   Required    — must be set; no working default or default is unsafe in prod
#   Recommended — has a default but operator should choose deliberately for prod
#   Optional    — feature-flag / provider-specific; leave blank if unused
#
# Secret rotation procedure: docs/SECRET_ROTATION.md
# Backup-scoped subset:      see docs/BACKUP_AND_RESTORE.md §2.3

# =============================================================================
# Section: required
# =============================================================================

# Postgres connection. Username, password, host, port, dbname.
# Generate the password with: openssl rand -hex 24
DATABASE_URL=postgresql://egp:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/egp

# Supabase Storage — OPTIONAL legacy artifact backend (only used when
# EGP_ARTIFACT_STORE=supabase). The default is Cloudflare R2 (s3) below;
# leave these as placeholders if you use R2. (Supabase is NOT used for auth
# or the database — auth is EGP_JWT_SECRET, the DB is Postgres.)
SUPABASE_URL=https://CHANGE_ME_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=egp-documents

# JWT signing secret for API authn. Must be at least 32 bytes of entropy.
# Generate with: openssl rand -hex 32
EGP_JWT_SECRET=CHANGE_ME_JWT_SECRET

# HMAC secret for payment-provider webhook callbacks.
# Generate with: openssl rand -hex 32
EGP_PAYMENT_CALLBACK_SECRET=CHANGE_ME_PAYMENT_CALLBACK_SECRET

# Token used by workers to call API internal endpoints.
# Generate with: openssl rand -hex 32
EGP_INTERNAL_WORKER_TOKEN=CHANGE_ME_INTERNAL_WORKER_TOKEN

# Public base URL of the API (used by payment-callback redirects, webhooks).
EGP_PAYMENT_BASE_URL=https://api.example.com

# Web origin allowlist (comma-separated). Browser CORS check.
EGP_WEB_ALLOWED_ORIGINS=https://app.example.com

# Public web base URL. Used in invoice links, magic-link emails, etc.
EGP_WEB_BASE_URL=https://app.example.com

# Cookie security in production. MUST be true behind HTTPS.
EGP_SESSION_COOKIE_SECURE=true

# Auth gate. MUST stay true in production; only false for local dev.
EGP_AUTH_REQUIRED=true

# =============================================================================
# Section: recommended
# =============================================================================

# Public API base URL used by workers to reach the API. Same as
# EGP_PAYMENT_BASE_URL behind a single Caddy/Nginx; can differ in split-host setups.
EGP_API_BASE_URL=https://api.example.com

# API server bind. Behind Caddy/Nginx, host=127.0.0.1 is fine.
EGP_API_HOST=127.0.0.1
EGP_API_PORT=8000

# Internal API base URL (worker → api). Leave blank to use EGP_PAYMENT_BASE_URL.
EGP_INTERNAL_API_BASE_URL=http://127.0.0.1:8000
EGP_INTERNAL_API_TIMEOUT_SECONDS=30

# Worker-side API bearer token (legacy peer of EGP_INTERNAL_WORKER_TOKEN).
EGP_API_BEARER_TOKEN=CHANGE_ME_INTERNAL_WORKER_TOKEN
EGP_API_TIMEOUT_SECONDS=30

# Document storage backend: local | s3 (Cloudflare R2) | supabase
# Default = Cloudflare R2 via the s3 backend. boto3 reads AWS_ENDPOINT_URL_S3
# + AWS_* creds from the env (no app code). AWS_DEFAULT_REGION MUST be set
# (use 'auto' for R2) so download URLs are signed with SigV4. The off-box Mac
# crawler MUST use the SAME bucket/endpoint/creds (docs/REMOTE_LOCAL_CRAWLER.md).
EGP_ARTIFACT_STORE=s3
S3_BUCKET=egp-documents
AWS_ENDPOINT_URL_S3=https://CHANGE_ME_R2_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=auto
EGP_ARTIFACT_ROOT=/var/lib/egp/artifacts
EGP_ARTIFACT_PREFIX=

# Background-runtime mode. external = use systemd / supervisord to run workers.
EGP_BACKGROUND_RUNTIME_MODE=external

# Per-host concurrent crawler workers. See PR-08 admission control before raising.
EGP_DISCOVERY_WORKER_COUNT=1

# Browser per-worker isolation (PR-03). Range determines reserved CDP port pool.
EGP_BROWSER_CDP_PORT_BASE=9222
EGP_BROWSER_CDP_PORT_RANGE=200
EGP_BROWSER_PROFILE_ROOT=/var/lib/egp/browser-profiles

# e-GP host rate limiter (PR-06).
EGP_EGP_RPS=0.5
EGP_EGP_BURST=1
EGP_EGP_CIRCUIT_429_THRESHOLD=5
EGP_EGP_CIRCUIT_RESET_SECONDS=300

# Session cookie tunables.
EGP_SESSION_COOKIE_NAME=egp_session
EGP_SESSION_COOKIE_SAMESITE=lax
EGP_SESSION_MAX_AGE_SECONDS=2592000

# Optional CORS regex (in addition to EGP_WEB_ALLOWED_ORIGINS).
EGP_WEB_ALLOW_ORIGIN_REGEX=

# Payment provider selector: promptpay_manual | opn | stripe | mock_promptpay
# promptpay_manual = the 0-baht-fee personal-PromptPay QR + manual LINE slip
# verification path (bootstrap before a registered acquirer is onboarded).
EGP_PAYMENT_PROVIDER=opn

# Postgres backup destination (PR-A). target: r2 | local-fs
EGP_BACKUP_TARGET=r2
EGP_BACKUP_LOCAL_CACHE_DIR=/var/backups/egp-postgres
EGP_BACKUP_LOCAL_RETENTION_DAYS=14
EGP_BACKUP_LOCAL_KEEP_MIN=3
EGP_BACKUP_REMOTE_RETENTION_DAYS=30
EGP_BACKUP_REMOTE_KEEP_MIN=3

# Cloudflare R2 credentials (required if EGP_BACKUP_TARGET=r2).
EGP_BACKUP_R2_ACCOUNT_ID=CHANGE_ME_R2_ACCOUNT_ID
EGP_BACKUP_R2_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY_ID
EGP_BACKUP_R2_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_ACCESS_KEY
EGP_BACKUP_R2_BUCKET=egp-backups-prod
EGP_BACKUP_R2_OBJECT_PREFIX=prod/

# Artifact-bucket mirror (rclone copy → R2). PR-A scope-(b).
EGP_ARTIFACT_BACKUP_SRC_REMOTE=supabase-prod:egp-documents
EGP_ARTIFACT_BACKUP_DEST_REMOTE=r2-backups:egp-artifacts-mirror

# =============================================================================
# Section: optional
# =============================================================================

# --- OPN Payments (Thai PromptPay) ---
# Required if EGP_PAYMENT_PROVIDER=opn. Get from https://dashboard.omise.co/
EGP_OPN_PUBLIC_KEY=
EGP_OPN_SECRET_KEY=
EGP_OPN_WEBHOOK_SECRET=
EGP_PROMPTPAY_PROXY_ID=

# --- LINE OA manual PromptPay slip verification ---
# Required when EGP_PAYMENT_PROVIDER=promptpay_manual. Create the OA at
# https://www.linebiz.com/th/ and the channel at https://developers.line.biz/console/
# Channel secret (verifies inbound X-Line-Signature webhooks):
EGP_LINE_CHANNEL_SECRET=
# Channel access token (long-lived) for downloading slip images + pushing notices:
EGP_LINE_CHANNEL_ACCESS_TOKEN=
# Comma-separated LINE userIds that receive new-slip admin push notifications:
EGP_LINE_ADMIN_USER_IDS=
# Public LINE add-friend / OA deep link shown on the billing page 'send slip' button
# (e.g. https://line.me/R/ti/p/@your-oa-id):
EGP_LINE_ADD_URL=
# Base URL of the admin console used in admin push links (defaults to the web base URL):
EGP_ADMIN_CONSOLE_BASE_URL=

# --- Outbound email (SMTP) ---
# Required if any notification flow uses email.
EGP_SMTP_HOST=
EGP_SMTP_PORT=587
EGP_SMTP_USERNAME=
EGP_SMTP_PASSWORD=
EGP_SMTP_FROM=
EGP_SMTP_USE_TLS=true

# --- Google Drive document storage (alternative to Supabase Storage) ---
EGP_GOOGLE_DRIVE_CLIENT_ID=
EGP_GOOGLE_DRIVE_CLIENT_SECRET=
EGP_GOOGLE_DRIVE_REDIRECT_URI=
EGP_GOOGLE_DRIVE_SCOPES=

# --- Microsoft OneDrive document storage (alternative to Supabase Storage) ---
EGP_ONEDRIVE_CLIENT_ID=
EGP_ONEDRIVE_CLIENT_SECRET=
EGP_ONEDRIVE_REDIRECT_URI=
EGP_ONEDRIVE_SCOPES=

# Credentials envelope key used to encrypt per-tenant storage credentials at rest.
# Generate with: openssl rand -hex 32
EGP_STORAGE_CREDENTIALS_SECRET=

# --- AWS Lambda config (only when running OPN webhook handler via Lambda) ---
# Either point at an AWS Secrets Manager ARN or an SSM Parameter Store name.
EGP_LAMBDA_CONFIG_SECRET_ARN=
EGP_LAMBDA_CONFIG_SSM_PARAMETER=

# =============================================================================
# Section: required
# Docker Compose-only vars (referenced via ${VAR:?} in docker-compose.yml)
# =============================================================================

# Public web origins used by Caddy for TLS provisioning + redirects.
EGP_API_DOMAIN=api.example.com
EGP_APP_DOMAIN=app.example.com

# Postgres credentials interpolated into the in-Compose DATABASE_URL.
# The standalone DATABASE_URL above is the source of truth for systemd
# deploys; these three vars are how docker compose composes the same URL.
EGP_POSTGRES_DB=egp
EGP_POSTGRES_USER=egp
EGP_POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Next.js client-side env vars (compiled into the apps/web bundle).
NEXT_PUBLIC_EGP_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_SITE_URL=https://app.example.com

# =============================================================================
# Section: optional
# Resend email provider (alternative to SMTP)
# =============================================================================

# Set EGP_RESEND_API_KEY if you use Resend instead of SMTP for outbound email.
EGP_RESEND_API_KEY=
EGP_RESEND_FROM=

# --- Observability stack (docker-compose.monitoring.yml overlay) ---
# Required only when running the monitoring overlay (Prometheus + Grafana).
# See docs/OBSERVABILITY.md for setup; rotation in docs/SECRET_ROTATION.md §10.
# Generate with: openssl rand -hex 24
EGP_GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# --- Stripe Payments (alternative to OPN) ---
# Required if EGP_PAYMENT_PROVIDER=stripe. Get from https://dashboard.stripe.com/apikeys
# Test keys: sk_test_/pk_test_ ; live keys: sk_live_/pk_live_
EGP_STRIPE_SECRET_KEY=
EGP_STRIPE_WEBHOOK_SECRET=
EGP_STRIPE_PUBLISHABLE_KEY=

# Residential-runner browser knobs. Defaults preserve the legacy per-run behaviour.
# profile_mode=persistent reuses one warmed profile dir (keeps Turnstile clearance);
# set the dir OUTSIDE any cloud-synced folder. Leave proxy/chrome path blank unless set.
EGP_BROWSER_PROFILE_MODE=per_run
EGP_BROWSER_PERSISTENT_PROFILE_DIR=
EGP_BROWSER_CHROME_PATH=
EGP_BROWSER_PROXY_SERVER=
EGP_BROWSER_USE_XVFB=false

# Upstream residential proxy URL for the gost proxy-relay (compose `proxy` profile).
# Format: http://USER:PASS@host:port. Set ONLY in /etc/egp/egp.env, never here.
EGP_PROXY_UPSTREAM_URL=

# Crawler search-step timeouts (PR 2a). Defaults = current behavior; raise for slow proxies.
EGP_BROWSER_NAV_TIMEOUT_MS=60000
EGP_BROWSER_CLOUDFLARE_TIMEOUT_MS=120000
EGP_BROWSER_CLOUDFLARE_RELOAD_RETRIES=1
EGP_BROWSER_CLOUDFLARE_OPERATOR_TIMEOUT_MS=600000
EGP_BROWSER_WARMUP_FAILURE_PAUSE_THRESHOLD=2
EGP_BROWSER_PROJECT_DETAIL_TIMEOUT_S=240

# Warm-up tool knobs (docs/CRAWLER_PROXY_RUNBOOK.md; python -m egp_worker.warmup).
EGP_BROWSER_WARMUP_CDP_PORT=9320
EGP_BROWSER_WARMUP_SECONDS=45

# On-demand persistent-profile warmup (profile_mode=persistent only). The
# dispatcher re-warms the profile before a crawl when it is older than the
# staleness window, then holds the browser for the pre-dispatch warm seconds.
# Defaults = current behavior (re-warm after 30 min; no extra hold).
EGP_BROWSER_WARMUP_STALE_AFTER_SECONDS=1800
EGP_BROWSER_PREDISPATCH_WARM_SECONDS=0
