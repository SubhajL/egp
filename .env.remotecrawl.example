# ──────────────────────────────────────────────────────────────────────────
# TRACK C — REMOTE crawler env. THIS FILE POINTS AT PRODUCTION.
#
# Copy to `.env.remotecrawl` (gitignored), then `chmod 600 .env.remotecrawl`.
# scripts/run_remote_crawl.sh validates this via scripts/remote_crawl_guard.py
# and refuses to start until every CHANGE_ME placeholder below is replaced.
#
# This is NOT the Lightsail host env file (deploy/.env.production.example) and
# NOT the localdev file (.env.localdev). It runs ONLY on the operator's Mac.
# ──────────────────────────────────────────────────────────────────────────

# Explicit acknowledgement that this Mac writes the PRODUCTION control-plane.
# Replace the placeholder with EXACTLY this value (a conscious opt-in):
#     I_UNDERSTAND_THIS_WRITES_PRODUCTION
# The guard rejects any CHANGE_ME placeholder, so copying the template alone
# never counts as acknowledgement.
EGP_REMOTECRAWL_PRODUCTION_ACK=CHANGE_ME_SET_TO_THE_ACK_VALUE_IN_THE_COMMENT_ABOVE

# ── Database (Topology A: SSH tunnel to Lightsail Postgres) ────────────────
# Open the tunnel first:  scripts/run_remote_crawl.sh tunnel
# The guard refuses localhost:5434 (the localdev DB) and refuses a direct
# non-loopback host unless it carries sslmode=require (Topology B). The
# loopback port MUST match EGP_REMOTECRAWL_TUNNEL_LOCAL_PORT below.
DATABASE_URL=postgresql://egp:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:15432/egp
EGP_REMOTECRAWL_SSH_HOST=ubuntu@CHANGE_ME_LIGHTSAIL_HOST
EGP_REMOTECRAWL_TUNNEL_LOCAL_PORT=15432
EGP_REMOTECRAWL_TUNNEL_REMOTE_PORT=15432

# ── Control-plane API (events posted back over HTTPS) ─────────────────────
EGP_INTERNAL_API_BASE_URL=https://api.CHANGE_ME_DOMAIN
EGP_INTERNAL_WORKER_TOKEN=CHANGE_ME_INTERNAL_WORKER_TOKEN
# Sanitized global runtime identity/heartbeat (never tenant or customer data).
EGP_CRAWLER_AGENT_ID=primary-mac-crawler
EGP_CRAWLER_HEARTBEAT_INTERVAL_SECONDS=30

# ── Artifacts: Cloudflare R2 (s3 backend) so the API can serve documents ───
# boto3 reads AWS_ENDPOINT_URL_S3 + AWS_* creds from the environment directly
# (no app code change). The Lightsail API MUST use the SAME bucket + endpoint +
# credentials so it can serve (via signed URLs) what this Mac uploads.
EGP_ARTIFACT_STORE=s3
S3_BUCKET=egp-documents
AWS_ENDPOINT_URL_S3=https://CHANGE_ME_R2_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=auto  # 'auto' for R2; forces SigV4 presigned URLs

# ── Browser: REAL Chrome + warmed persistent single-flight profile ────────
EGP_BROWSER_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
EGP_BROWSER_PROFILE_MODE=persistent
# Keep OUTSIDE OneDrive/iCloud/Dropbox (profiles corrupt in synced folders).
EGP_BROWSER_PERSISTENT_PROFILE_DIR=/Users/CHANGE_ME_USER/.egp/profiles/prod
# The watcher warms/preflights this profile only before a claimed crawl when the
# last successful warm/crawl is older than this window. Set to 1200-1800 in prod.
EGP_BROWSER_WARMUP_STALE_AFTER_SECONDS=1800
# Stop unattended pre-dispatch warm retries after this many consecutive failures.
EGP_BROWSER_WARMUP_FAILURE_PAUSE_THRESHOLD=2
# Keep the on-demand warm quick; the optional launchd warm timer can hold longer.
EGP_BROWSER_PREDISPATCH_WARM_SECONDS=0
EGP_DISCOVERY_WORKER_COUNT=1
# Keep long crawls owned while the worker is alive; expired claims are reclaimable.
EGP_DISCOVERY_LEASE_SECONDS=60
EGP_DISCOVERY_LEASE_HEARTBEAT_SECONDS=20

# Pure control-plane on Lightsail; the Mac is the only crawler.
EGP_BACKGROUND_RUNTIME_MODE=external
