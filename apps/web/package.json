    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "openapi-typescript": "^7.13.0",
