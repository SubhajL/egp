# Docker Compose auto-loads this file when present as `.env` at the repo root.
# Local `uvicorn` runs can use the same file with:
#   set -a; source .env; set +a

# Background execution mode:
# - embedded: API process runs background loops when the database backend supports them.
# - external: API serves HTTP only; run webhook/discovery executors as separate processes.
EGP_BACKGROUND_RUNTIME_MODE=embedded
EGP_CRAWLER_HEARTBEAT_STALE_AFTER_SECONDS=90

# Renewable discovery claims. The heartbeat must be shorter than the lease.
EGP_DISCOVERY_LEASE_SECONDS=60
EGP_DISCOVERY_LEASE_HEARTBEAT_SECONDS=20

# Preferred transactional provider: Resend
EGP_EMAIL_PROVIDER=resend
EGP_RESEND_API_KEY=re_replace_with_real_key
EGP_RESEND_FROM="e-GP Intelligence <noreply@example.com>"
EGP_RESEND_API_BASE=https://api.resend.com

# Optional SMTP fallback
EGP_SMTP_HOST=
EGP_SMTP_PORT=587
EGP_SMTP_USERNAME=
EGP_SMTP_PASSWORD=
EGP_SMTP_FROM=noreply@example.com
EGP_SMTP_USE_TLS=true
